# frozen_string_literal: true

if File.exist?(File.join(Dir.getwd, "config", "environment.rb")) # Is Rails app?
  def active_record_logger_on
    ActiveRecord::Base.logger = Logger.new($stdout)
  end

  def active_record_logger_off
    ActiveRecord::Base.logger = nil
  end

  # Load FactoryBot factories and Faker into the current Rails console session (development env)
  def fb # rubocop:disable Metrics/MethodLength, Naming/PredicateMethod
    puts "Loading FactoryBot..."
    require "factory_bot"

    begin
      require "faker"
      puts "Faker loaded!"
    rescue LoadError
      begin
        require "ffaker"
        puts "FFaker loaded!"
      rescue LoadError => e
        puts "=> Unable to load [F]Faker (#{e})"
      end
    end

    factory_bot_config = Rails.root.join("spec", "support", "factory_bot.rb")

    if File.exist?(factory_bot_config)
      load factory_bot_config
      puts "Loaded #{factory_bot_config}"
    end

    FactoryBot.find_definitions if FactoryBot.factories.none?

    # Intentionally included at top level to make build/create available in the console
    include FactoryBot::Syntax::Methods # rubocop:disable Style/MixinUsage

    true
  end
end
